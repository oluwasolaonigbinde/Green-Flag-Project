{
  "openapi": "3.1.0",
  "info": {
    "title": "Green Flag Award Foundation API",
    "version": "0.0.0",
    "description": "Slice 0 foundation API skeleton. Business workflows are implemented by later backlog slices."
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Return foundation API health.",
        "responses": {
          "200": {
            "description": "API is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/contract-metadata": {
      "get": {
        "operationId": "getContractMetadata",
        "summary": "Return baseline contract metadata for scaffold validation.",
        "responses": {
          "200": {
            "description": "Contract metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContractMetadataResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "service", "version"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"]
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "ContractMetadataResponse": {
        "type": "object",
        "required": ["slice", "episodeFirst", "safeDisplayStatuses", "forbiddenProductionValues"],
        "properties": {
          "slice": {
            "type": "string"
          },
          "episodeFirst": {
            "type": "boolean"
          },
          "safeDisplayStatuses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbiddenProductionValues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {}
            }
          }
        }
      }
    }
  }
}
